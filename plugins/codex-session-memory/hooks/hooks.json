{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/session_start.py",
            "timeout": 30,
            "statusMessage": "Loading Codex session memory"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/stop.py",
            "timeout": 210,
            "statusMessage": "Saving Codex session memory"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|mcp.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/post_tool_use.py",
            "timeout": 30,
            "statusMessage": "Marking Codex session evidence"
          }
        ]
      }
    ]
  }
}
