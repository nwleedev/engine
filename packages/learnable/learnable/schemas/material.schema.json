{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/learnable/material.schema.json",
  "title": "Learnable material record",
  "type": "object",
  "x-learnable-rules": [
    "provenance runtime id values must not be used as learnable_session_id, node_id, or parent_node_id"
  ],
  "required": [
    "schema_version",
    "learnable_session_id",
    "node_id",
    "parent_node_id",
    "title",
    "depth",
    "status",
    "source_refs",
    "created_from_prompt",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "learnable_session_id": { "type": "string" },
    "node_id": { "type": "string" },
    "parent_node_id": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "title": { "type": "string" },
    "depth": { "type": "integer" },
    "status": { "type": "string" },
    "source_refs": {
      "type": "array",
      "items": {
        "anyOf": [{ "type": "string" }, { "type": "object" }]
      }
    },
    "created_from_prompt": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "type": "string",
          "enum": ["codex", "claude", "unknown"]
        },
        "codex_thread_id": { "type": "string" },
        "codex_session_id": { "type": "string" },
        "codex_turn_id": { "type": "string" },
        "app_server_thread_id": { "type": "string" },
        "diagnostics": { "type": "object" }
      }
    }
  },
  "not": {
    "anyOf": [
      { "required": ["codex_thread_id"] },
      { "required": ["codex_session_id"] },
      { "required": ["codex_turn_id"] },
      { "required": ["app_server_thread_id"] }
    ]
  }
}
