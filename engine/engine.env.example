# .claude/engine.env — per-project engine plugin settings
# Copy this file to .claude/engine.env in your project to use.
#
# All settings are optional; defaults apply when unset.

# === Work Review Settings ===

# Work review perspectives (comma-separated, free-form)
# Applied when files are edited: work-reviewer runs in parallel by perspective.
# Examples: "domain,structure", "domain,structure,requirements", "security,performance"
# When unset: default multi-review (2 parallel reviewers without perspective distinction)
# WORK_REVIEW_PERSPECTIVES="domain,structure"

# Review trigger thresholds (based on number of modified files)
# REVIEW_THRESHOLD_SINGLE=2    # Start single review
# REVIEW_THRESHOLD_MULTI=5     # Start parallel review

# === Plan Review Settings ===

# Plan review perspectives (comma-separated, free-form)
# Applied on ExitPlanMode: plan-readiness-checker runs in parallel by perspective
# before the plan can be approved.
# Examples: "structure,steps,requirements", "feasibility,risks,completeness"
# When unset: default single-pass checklist review
# PLAN_REVIEW_PERSPECTIVES="structure,steps,requirements"

# === Research Settings ===

# Research agent perspectives (comma-separated)
# When set, project-researcher is invoked in parallel by perspective
# Examples: "pro,con", "advantages,disadvantages,risks"
# When unset: single agent investigates both sides (default behavior)
# RESEARCH_PERSPECTIVES="pro,con"
